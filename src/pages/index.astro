---
import { getCollection, type CollectionEntry } from 'astro:content';
import BlogPostList from '../components/BlogPostList.astro';
import BaseLayout from '../layouts/BaseLayout.astro';

import Marquee from '../components/Marquee.astro';

type BlogPost = CollectionEntry<'blog'>;

const posts = await getCollection('blog');
posts.sort((a: BlogPost, b: BlogPost) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---
<style>
  body {
    max-width: 720px;
    margin: auto;
  }
  iframe {
    border: none;
    margin: 0;
    padding: 0;
    overflow: hidden;
  }
</style>

<BaseLayout title="さこちゃねる">
  <Marquee message="なんと令和にさこちゃねるが復活！" duration="15s" />
  <iframe src="https://oekaki.sakots.net/count/count.php" height="40" width="220"></iframe>
  <BlogPostList posts={posts} />
</BaseLayout>
