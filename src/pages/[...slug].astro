---
// src/pages/[...slug].astro (新規作成、src/pages/blog/[id].astro は削除)
import { getCollection, render, type CollectionEntry } from 'astro:content';
import type { ImageMetadata } from 'astro';
import ImageGallery from '../components/ImageGallery.astro';
import BaseLayout from '../layouts/BaseLayout.astro'; // レイアウトへのパスが変わることに注意
import '../styles/gallery.scss';
import { compareImagePathsByTimestamp, getLatestImageDate } from '../utils/imageSort';
import { getRelativeRoot } from '../utils/url';

const IMAGES_PER_PAGE = 50;

type BlogPost = CollectionEntry<'blog'>;
type GalleryImage = {
  src: ImageMetadata;
  alt: string;
};

interface Props {
  post: BlogPost;
  currentPage: number;
  totalPages: number;
  totalImages: number;
}

const imageModules = import.meta.glob<{ default: ImageMetadata }>('../imgs/**/*.{png,jpg,jpeg,webp,gif}', {
  eager: true,
});

function getSlugPath(post: BlogPost) {
  return post.data.url ?? post.id.replace(/\.md$/, '');
}

function getGalleryImages(post: BlogPost): GalleryImage[] {
  return post.data.imageDir
    ? Object.entries(imageModules)
        .filter(([path]) => path.includes(`../imgs/${post.data.imageDir}/`))
        .sort(([pathA], [pathB]) => compareImagePathsByTimestamp(pathA, pathB))
        .map(([path, image]) => ({
          src: image.default,
          alt: `${post.data.title} ${path.split('/').pop()?.replace(/\.[^.]+$/, '') ?? ''}`,
        }))
    : [];
}

function getPageSlug(slugPath: string, page: number) {
  return page === 1 ? slugPath : `${slugPath}/page/${page}`;
}

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  const imagesPerPage = 50;
  const staticImageModules = import.meta.glob<{ default: ImageMetadata }>('../imgs/**/*.{png,jpg,jpeg,webp,gif}', {
    eager: true,
  });

  return posts.flatMap((post: BlogPost) => {
    const slugPath = post.data.url ?? post.id.replace(/\.md$/, '');
    const totalImages = post.data.imageDir
      ? Object.keys(staticImageModules).filter((path) => path.includes(`../imgs/${post.data.imageDir}/`)).length
      : 0;
    const totalPages = Math.max(1, Math.ceil(totalImages / imagesPerPage));

    return Array.from({ length: totalPages }, (_, index) => {
      const currentPage = index + 1;
      const pageSlug = currentPage === 1 ? slugPath : `${slugPath}/page/${currentPage}`;

      return {
        params: { slug: pageSlug },
        props: { post, currentPage, totalPages, totalImages },
      };
    });
  });
}

const { post, currentPage, totalPages, totalImages } = Astro.props;
const { Content } = await render(post);
const rootUrl = getRelativeRoot(Astro.url.pathname);
const slugPath = getSlugPath(post);
const pageStartIndex = (currentPage - 1) * IMAGES_PER_PAGE;
const pageEndIndex = pageStartIndex + IMAGES_PER_PAGE;
const allGalleryImages = getGalleryImages(post);
const galleryImagePaths = post.data.imageDir
  ? Object.keys(imageModules).filter((path) => path.includes(`../imgs/${post.data.imageDir}/`))
  : [];
const updatedAt = getLatestImageDate(galleryImagePaths);
const galleryImages = allGalleryImages.slice(pageStartIndex, pageEndIndex);
const pageNumbers = Array.from({ length: totalPages }, (_, index) => index + 1);

function getPageUrl(page: number) {
  return `${rootUrl}${getPageSlug(slugPath, page)}/`;
}
---
<BaseLayout title={totalPages > 1 ? `${post.data.title} (${currentPage}/${totalPages})` : post.data.title}>
  <nav class="post-nav" aria-label="記事ナビゲーション">
    <a href={rootUrl}>トップページへ戻る</a>
  </nav>

  <article class="gallery-page">
    <ul class="gallery-page__meta" aria-label="ギャラリー情報">
      <li>
        <span class="gallery-page__label">公開日</span>
        <time datetime={post.data.pubDate.toISOString()}>{post.data.pubDate.toLocaleDateString('ja-JP')}</time>
      </li>
      {updatedAt && (
        <li>
          <span class="gallery-page__label">更新日</span>
          <time datetime={updatedAt.toISOString()}>{updatedAt.toLocaleDateString('ja-JP')}</time>
        </li>
      )}
      {post.data.tags && post.data.tags.length > 0 && (
        <li>
          <span class="gallery-page__label">タグ</span>
          <ul class="gallery-tags" aria-label="タグ一覧">
            {post.data.tags.map((tag) => <li>{tag}</li>)}
          </ul>
        </li>
      )}
    </ul>
    <div class="gallery-page__description">
      {post.data.description && <p>{post.data.description}</p>}
      <Content />
    </div>
    {totalPages > 1 && (
      <p class="image-count">
        画像 {pageStartIndex + 1}-{Math.min(pageEndIndex, totalImages)} / {totalImages}
      </p>
    )}
    {totalPages > 1 && (
      <nav class="pagination" aria-label="画像ページ">
        {currentPage > 1 ? (
          <a href={getPageUrl(currentPage - 1)} rel="prev">前へ</a>
        ) : (
          <span aria-disabled="true">前へ</span>
        )}
        <ol>
          {pageNumbers.map((page) => (
            <li>
              {page === currentPage ? (
                <span aria-current="page">{page}</span>
              ) : (
                <a href={getPageUrl(page)}>{page}</a>
              )}
            </li>
          ))}
        </ol>
        {currentPage < totalPages ? (
          <a href={getPageUrl(currentPage + 1)} rel="next">次へ</a>
        ) : (
          <span aria-disabled="true">次へ</span>
        )}
      </nav>
    )}
    <ImageGallery images={galleryImages} />
    {totalPages > 1 && (
      <nav class="pagination" aria-label="画像ページ">
        {currentPage > 1 ? (
          <a href={getPageUrl(currentPage - 1)} rel="prev">前へ</a>
        ) : (
          <span aria-disabled="true">前へ</span>
        )}
        <ol>
          {pageNumbers.map((page) => (
            <li>
              {page === currentPage ? (
                <span aria-current="page">{page}</span>
              ) : (
                <a href={getPageUrl(page)}>{page}</a>
              )}
            </li>
          ))}
        </ol>
        {currentPage < totalPages ? (
          <a href={getPageUrl(currentPage + 1)} rel="next">次へ</a>
        ) : (
          <span aria-disabled="true">次へ</span>
        )}
      </nav>
    )}
  </article>

  <nav class="post-nav" aria-label="記事ナビゲーション">
    <a href={rootUrl}>トップページへ戻る</a>
  </nav>
</BaseLayout>
