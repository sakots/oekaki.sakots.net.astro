---
// src/pages/[...slug].astro (新規作成、src/pages/blog/[id].astro は削除)
import { getCollection, render, type CollectionEntry } from 'astro:content';
import type { ImageMetadata } from 'astro';
import ImageGallery from '../components/ImageGallery.astro';
import BaseLayout from '../layouts/BaseLayout.astro'; // レイアウトへのパスが変わることに注意

type BlogPost = CollectionEntry<'blog'>;
type GalleryImage = {
  src: ImageMetadata;
  alt: string;
};

interface Props {
  post: BlogPost;
}

export async function getStaticPaths() {
  const posts = await getCollection('blog');

  return posts.map((post: BlogPost) => {
    const slugPath = post.data.url ?? post.id.replace(/\.md$/, '');

    return {
      params: { slug: slugPath },
      props: { post },
    };
  });
}

const { post } = Astro.props;
const { Content } = await render(post);

const imageModules = import.meta.glob<{ default: ImageMetadata }>('../imgs/**/*.{png,jpg,jpeg,webp,gif}', {
  eager: true,
});

const galleryImages: GalleryImage[] = post.data.imageDir
  ? Object.entries(imageModules)
      .filter(([path]) => path.includes(`../imgs/${post.data.imageDir}/`))
      .sort(([pathA], [pathB]) => pathA.localeCompare(pathB))
      .map(([path, image]) => ({
        src: image.default,
        alt: `${post.data.title} ${path.split('/').pop()?.replace(/\.[^.]+$/, '') ?? ''}`,
      }))
  : [];
---
<BaseLayout title={post.data.title}>
  <article>
    <h1>{post.data.title}</h1>
    <p>公開日: {post.data.pubDate.toLocaleDateString()}</p>
    {post.data.tags && (
      <p>タグ: {post.data.tags.join(', ')}</p>
    )}
    <hr />
    <Content />
    <ImageGallery images={galleryImages} />
  </article>
</BaseLayout>
