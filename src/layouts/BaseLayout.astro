---
import { withRelativeRoot } from '../utils/url';

interface Props {
  title?: string;
  author?: string;
  frontmatter?: {
    title?: string;
    author?: string;
  };
}

const { title, author, frontmatter } = Astro.props;
const pageTitle = title ?? frontmatter?.title ?? 'さこちゃねる';
const pageAuthor = author ?? frontmatter?.author ?? 'さこちゃねる';
const faviconUrl = withRelativeRoot(Astro.url.pathname, 'favicon.ico');

const canonicalURL = new URL(Astro.url.pathname, 'https://oekaki.sakots.net');
const ogpImageURL = new URL('/ogp.png', canonicalURL);

---
<html lang="ja">
  <head prefix="og: https://ogp.me/ns#">
    <meta charset="utf-8" />
    <link rel="icon" href={faviconUrl} />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta property="og:image" content={ogpImageURL} />
    <meta property="og:title" content="さこちゃねる（令和最新版）" />
    <meta property="og:description" content="なんとさこちゃねるが令和に復活" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogpImageURL} />
    <meta property="og:site_name" content="さこちゃねる" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="さこちゃねる（令和最新版）" />
    <meta name="twitter:description" content="なんとさこちゃねるが令和に復活" />
  </head>
  <body>
    <header>
      <h1>{pageTitle}</h1>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      <p>&copy; {new Date().getFullYear()} {pageAuthor}. All rights reserved.</p>
    </footer>
  </body>
</html>
