---
import type { ImageMetadata } from 'astro';
import { withRelativeRoot } from '../utils/url';

interface GalleryImage {
  src: ImageMetadata;
  alt: string;
}

interface Props {
  images: GalleryImage[];
}

const { images } = Astro.props;
const luminousCssUrl = withRelativeRoot(Astro.url.pathname, 'vendor/luminous/luminous-basic.min.css');
const luminousScriptUrl = withRelativeRoot(Astro.url.pathname, 'vendor/luminous/luminous.min.js');

function getImageSrc(src: string) {
  return src.startsWith('/') ? withRelativeRoot(Astro.url.pathname, src) : src;
}
---
{images.length > 0 && (
  <>
    <link rel="stylesheet" href={luminousCssUrl} />
    <section class="image-gallery" aria-label="画像ギャラリー">
      {images.map((image) => (
        <figure>
          <a href={getImageSrc(image.src.src)} class="luminous-gallery-item">
            <img src={getImageSrc(image.src.src)} alt={image.alt} loading="lazy" />
          </a>
        </figure>
      ))}
    </section>
    <script is:inline src={luminousScriptUrl}></script>
    <script is:inline>
      (() => {
        const galleryItems = document.querySelectorAll('.luminous-gallery-item');

        if (galleryItems.length > 0 && window.LuminousGallery) {
          new window.LuminousGallery(galleryItems);
        }
      })();
    </script>
  </>
)}

<style>
  .image-gallery {
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 400px), 400px));
    justify-content: start;
    margin-top: 2rem;
  }

  .image-gallery figure {
    margin: 0;
  }

  .image-gallery a {
    display: block;
  }

  .image-gallery img {
    display: block;
    height: auto;
    max-width: 100%;
    width: 400px;
  }
</style>
