---
import type { ImageMetadata } from 'astro';
import 'luminous-lightbox/dist/luminous-basic.css';
import { withRelativeRoot } from '../utils/url';

interface GalleryImage {
  src: ImageMetadata;
  alt: string;
}

interface Props {
  images: GalleryImage[];
}

const { images } = Astro.props;

function getImageSrc(src: string) {
  return src.startsWith('/') ? withRelativeRoot(Astro.url.pathname, src) : src;
}
---
{images.length > 0 && (
  <section class="image-gallery" aria-label="画像ギャラリー">
    {images.map((image) => (
      <figure>
        <a href={getImageSrc(image.src.src)} class="luminous-gallery-item">
          <img src={getImageSrc(image.src.src)} alt={image.alt} loading="lazy" />
        </a>
      </figure>
    ))}
  </section>
)}

<script>
  import { LuminousGallery } from 'luminous-lightbox';

  const galleryItems = document.querySelectorAll<HTMLAnchorElement>('.luminous-gallery-item');

  if (galleryItems.length > 0) {
    new LuminousGallery(galleryItems);
  }
</script>

<style>
  .image-gallery {
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    margin-top: 2rem;
  }

  .image-gallery figure {
    margin: 0;
  }

  .image-gallery a {
    display: block;
  }

  .image-gallery img {
    display: block;
    height: auto;
    width: 100%;
  }
</style>
