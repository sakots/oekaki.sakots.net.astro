---
import type { ImageMetadata } from 'astro';
import type { CollectionEntry } from 'astro:content';
import { compareImagePathsByTimestampDescending, getLatestImageDate } from '../utils/imageSort';
import { withRelativeRoot } from '../utils/url';

type BlogPost = CollectionEntry<'blog'>;
type ImageModule = {
  default: ImageMetadata;
};
type PostListItem = {
  post: BlogPost;
  thumbnailSrc?: string;
  updatedAt?: Date;
};

interface Props {
  posts: BlogPost[];
}

const { posts } = Astro.props;
const imageModules = import.meta.glob<ImageModule>('../imgs/**/*.{png,jpg,jpeg,webp,gif}', {
  eager: true,
});

function getPostUrl(post: BlogPost) {
  const slugPath = post.data.url ?? post.id.replace(/\.md$/, '');

  return withRelativeRoot(Astro.url.pathname, `${slugPath}/`);
}

function getPostThumbnail(post: BlogPost) {
  if (!post.data.imageDir) {
    return undefined;
  }

  const latestImage = Object.entries(imageModules)
    .filter(([path]) => path.includes(`../imgs/${post.data.imageDir}/`))
    .sort(([pathA], [pathB]) => compareImagePathsByTimestampDescending(pathA, pathB))[0]?.[1].default;

  if (!latestImage) {
    return undefined;
  }

  return latestImage.src.startsWith('/')
    ? withRelativeRoot(Astro.url.pathname, latestImage.src)
    : latestImage.src;
}

function getPostUpdatedAt(post: BlogPost) {
  if (!post.data.imageDir) {
    return undefined;
  }

  const imagePaths = Object.keys(imageModules)
    .filter((path) => path.includes(`../imgs/${post.data.imageDir}/`));

  return getLatestImageDate(imagePaths);
}

const postItems: PostListItem[] = posts
  .map((post) => ({
    post,
    thumbnailSrc: getPostThumbnail(post),
    updatedAt: getPostUpdatedAt(post),
  }))
  .sort((itemA, itemB) => {
    const isUncategorizedA = itemA.post.data.url === 'uncategorized';
    const isUncategorizedB = itemB.post.data.url === 'uncategorized';

    if (isUncategorizedA !== isUncategorizedB) {
      return isUncategorizedA ? 1 : -1;
    }

    const dateA = itemA.updatedAt ?? itemA.post.data.pubDate;
    const dateB = itemB.updatedAt ?? itemB.post.data.pubDate;

    return dateB.valueOf() - dateA.valueOf();
  });
---
<section class="post-list" aria-labelledby="post-list-title">
  <h2 id="post-list-title">記事一覧</h2>

  {postItems.length > 0 ? (
    <ul>
      {postItems.map(({ post, thumbnailSrc, updatedAt }: PostListItem) => (
        <li style={thumbnailSrc ? `background-image: url("${thumbnailSrc}");` : undefined}>
          <div class="post-summary">
            <a href={getPostUrl(post)}>{post.data.title}</a>
            <time datetime={post.data.pubDate.toISOString()}>
              公開日: {post.data.pubDate.toLocaleDateString('ja-JP')}
            </time>
            {updatedAt && (
              <time datetime={updatedAt.toISOString()}>
                更新日: {updatedAt.toLocaleDateString('ja-JP')}
              </time>
            )}
            {post.data.description && <p>{post.data.description}</p>}
            {post.data.tags && (
              <ul class="tags" aria-label="タグ">
                {post.data.tags.map((tag) => <li>{tag}</li>)}
              </ul>
            )}
          </div>
        </li>
      ))}
    </ul>
  ) : (
    <p>記事はまだありません。</p>
  )}
</section>
